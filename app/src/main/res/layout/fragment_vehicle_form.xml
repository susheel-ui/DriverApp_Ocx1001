<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".Fragments.Vehicle_formFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ================= PAGE TITLE ================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vehicle Details"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="18dp"/>


            <!-- ================= VEHICLE NUMBER ================= -->
            <TextView
                android:text="Vehicle Number *"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/vehicleNumberEditText"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/edit_text_background"
                android:hint="Enter vehicle number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:layout_marginBottom="22dp"/>


            <!-- ================= RC UPLOAD CARD ================= -->
            <LinearLayout
                android:id="@+id/vehicleRcLayout"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/upload_item_background"
                android:layout_marginBottom="26dp">

                <TextView
                    android:text="Vehicle RC"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/uploadRC"
                    android:text="Upload"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFD500"
                    android:drawableStart="@drawable/camera_icon"
                    android:drawablePadding="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>


            <!-- ================= CITY ================= -->
            <TextView
                android:text="City of operation"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/edit_text_background"
                android:layout_marginBottom="26dp">

                <Spinner
                    android:id="@+id/citySpinner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@android:color/transparent"/>
            </RelativeLayout>


            <!-- ================= VEHICLE TYPE ================= -->
            <TextView
                android:text="Vehicle Type"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="24dp">

                <!-- CARD TEMPLATE -->
                <LinearLayout
                    android:id="@+id/cardTruck"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:layout_marginEnd="10dp"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="110dp"
                        android:layout_height="60dp"
                        android:src="@drawable/v4w"/>

                    <TextView
                        android:text="Truck"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginTop="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/card3W"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:layout_marginEnd="10dp"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="110dp"
                        android:layout_height="60dp"
                        android:src="@drawable/v3w"/>

                    <TextView
                        android:text="3W"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginTop="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/card2W"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="110dp"
                        android:layout_height="60dp"
                        android:src="@drawable/v2w"/>

                    <TextView
                        android:text="2W"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginTop="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>


            <!-- ================= FUEL TYPE ================= -->
            <TextView
                android:id="@+id/subVehicleTitle"
                android:text="Fuel Type"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/subVehicleContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/subCard1"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:id="@+id/subText1"
                        android:text="EV"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/subCard2"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:id="@+id/subText2"
                        android:text="Petrol"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/subCard3"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/vehicle_card_selector"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/subText3"
                        android:text="CNG"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>


    <!-- ================= LOADING OVERLAY ================= -->
    <FrameLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:gravity="center">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"/>
    </FrameLayout>

</FrameLayout>
