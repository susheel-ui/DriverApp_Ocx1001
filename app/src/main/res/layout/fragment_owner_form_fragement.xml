<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".Fragments.Owner_formFragement">

    <!-- ================= CONTENT ================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ===== Owner Name ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/name_compulsory"
                android:textColor="#212121"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/editTextName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/name"
                android:background="@drawable/edit_text_background"
                android:padding="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="24dp"/>

            <!-- ===== Upload Section Title ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_the_following_compulsory"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ===== Aadhaar Front ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/upload_item_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/owner_aadhaar_card"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/uploadAadhaar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2979FF"
                    android:drawableStart="@drawable/camera_icon"
                    android:drawablePadding="8dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>

                <ImageView
                    android:id="@+id/tickAadhaar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_tick_green"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone"/>
            </RelativeLayout>

            <!-- ===== Aadhaar Back ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/upload_item_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owner Aadhaar Back Side"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/uploadAadhaarBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2979FF"
                    android:drawableStart="@drawable/camera_icon"
                    android:drawablePadding="8dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>

                <ImageView
                    android:id="@+id/tickAadhaarBack"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_tick_green"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone"/>
            </RelativeLayout>

            <!-- ===== PAN Card ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/upload_item_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/owner_pan_card"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/uploadPan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2979FF"
                    android:drawableStart="@drawable/camera_icon"
                    android:drawablePadding="8dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>

                <ImageView
                    android:id="@+id/tickPan"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_tick_green"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone"/>
            </RelativeLayout>

            <!-- ===== Selfie ===== -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/upload_item_background"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/driver_selfie"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/uploadSelfie"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/upload"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2979FF"
                    android:drawableStart="@drawable/camera_icon"
                    android:drawablePadding="8dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>

                <ImageView
                    android:id="@+id/tickSelfie"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_tick_green"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone"/>
            </RelativeLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ================= LOADING OVERLAY ================= -->
    <FrameLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"/>
    </FrameLayout>

</FrameLayout>
