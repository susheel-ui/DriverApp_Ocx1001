<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContent"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- ================= HEADER ================= -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        android:elevation="6dp"
        android:paddingHorizontal="18dp">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:src="@drawable/baseline_arrow_back_ios_24"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Profile"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <!-- ================= MAIN CONTENT ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="18dp"
        android:orientation="vertical">

        <!-- ================= PROFILE CARD ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/profile"
                android:scaleType="centerCrop"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDriverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Driver Name"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#111111"/>

                <TextView
                    android:id="@+id/txtDriverMobile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9999999999"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/txtDriverEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@email.com"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFIED"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1DB954"
                android:background="#E8F5E9"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>


        <!-- ================= WALLET CARD ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_wallet_card"
            android:padding="22dp"
            android:orientation="vertical"
            android:elevation="10dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Earnings"
                android:textColor="#E0E0E0"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/txtTotalEarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="6dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="14dp"
                android:background="#22FFFFFF"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWithdraw"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Withdraw Money"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="#FFD54F"
                android:background="@drawable/bg_withdraw_contrast"
                app:backgroundTint="@null"
                app:cornerRadius="18dp"/>


        </LinearLayout>


        <!-- ================= BANK CARD ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:elevation="8dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bank Details"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#111111"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditBank"
                    android:layout_width="130dp"
                    android:layout_height="42dp"
                    android:text="Edit Details"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="#FFC107"
                    android:layout_alignParentEnd="true"
                    app:cornerRadius="22dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="#FFC107"
                    app:backgroundTint="@android:color/white"/>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="14dp"
                android:background="#EEEEEE"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account Number"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>

            <TextView
                android:id="@+id/txtAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="•••• •••• •••• 1234"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <Space
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IFSC Code"
                android:textSize="12sp"
                android:textColor="#9E9E9E"/>

            <TextView
                android:id="@+id/txtIfsc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ZRK0001234"
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/txtBankStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Verified"
                android:textColor="#1DB954"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="14dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ================= LOGOUT ================= -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/logoutButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="18dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="#FF3B30"
        app:backgroundTint="@android:color/white"
        app:strokeColor="#FF3B30"
        app:strokeWidth="2dp"
        app:cornerRadius="18dp"/>

</LinearLayout>
