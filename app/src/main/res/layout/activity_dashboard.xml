<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8">

    <!-- ===================== MAIN CONTENT ===================== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ===== TOP BAR ===== -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="4dp"
                android:src="@drawable/ic_menu"/>

            <ImageView
                android:id="@+id/logoPorter"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_marginStart="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/zarkit_nobgblacklogo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="112dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_notification" />

                <ImageView
                    android:id="@+id/btnProfile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="2dp"
                    android:src="@drawable/ic_support"/>
            </LinearLayout>
        </LinearLayout>



        <!-- ===== GREETING ===== -->
        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hello, Captain 👋"
            android:textColor="#1A1A2E"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ===== VERIFICATION BANNER ===== -->
        <LinearLayout
            android:id="@+id/verificationBanner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:background="#FFF3E0"
            android:orientation="vertical"
            android:padding="14dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/txtGreeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️ Admin Verification Pending | स्वीकृति अभी बाकी है"
                android:textColor="#E65100"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="12sp"
                android:textColor="#BF360C"
                android:lineSpacingExtra="3dp"
                android:text="Your documents are under review by our team. Once approved, a ₹500 registration fee payment option will appear — complete the payment to start accepting orders.\n\nआपके दस्तावेज़ हमारी टीम द्वारा जाँचे जा रहे हैं। स्वीकृति मिलने के बाद ₹500 पंजीकरण शुल्क का भुगतान विकल्प दिखाई देगा — भुगतान पूरा करके ऑर्डर लेना शुरू करें\n\n📧 For faster approval, contact us at: support@zarkit.com"/>
        </LinearLayout>



        <!-- ===== DRIVER INFO CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/driverInfoCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            app:strokeColor="#F0F0F0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/verificationBanner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Profile + Status Dot -->
                <FrameLayout
                    android:layout_width="58dp"
                    android:layout_height="58dp">

                    <ImageView
                        android:id="@+id/imgDriver"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile"
                        android:background="@drawable/circle_white"
                        android:padding="2dp"/>

                    <ImageView
                        android:id="@+id/statusDot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="1dp"
                        android:background="@drawable/status_dot_green"
                        android:elevation="2dp"/>
                </FrameLayout>

                <!-- Name + Vehicle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtVehicleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Loading..."
                        android:textColor="#888888"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- View Profile -->
                <TextView
                    android:id="@+id/txtViewProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:background="@drawable/bg_view_profile_btn"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== EARNINGS CARD ===== -->
        <LinearLayout
            android:id="@+id/earningCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:padding="18dp"
            android:background="@drawable/bg_card"
            android:elevation="6dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/driverInfoCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Earnings Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtEarningsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Earnings"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/txtEarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#1A1A2E"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Pay Now -->
            <Button
                android:id="@+id/btnPayNow"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:backgroundTint="#D32F2F"
                android:text="Pay Now"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:stateListAnimator="@null"
                android:elevation="4dp"/>
        </LinearLayout>



        <!-- ===== PRODUCTIVE DAY CARD ===== -->
        <LinearLayout
            android:id="@+id/productiveDayCard"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_blue_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="22dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/earningCard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀  Ready for a productive day?"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Every journey counts.\nLet's make today your best one yet!"
                android:textColor="#CCDCFF"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"/>
        </LinearLayout>

        <!-- ===== GO ONLINE BUTTON ===== -->
        <RelativeLayout
            android:id="@+id/btnGoOnline"
            android:layout_width="0dp"
            android:layout_height="62dp"
            android:layout_margin="16dp"
            android:background="@drawable/btn_online"
            android:padding="6dp"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/txtOnlineStatus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="GO Online"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <FrameLayout
                android:id="@+id/sliderContainer"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_white"/>

                <ImageView
                    android:id="@+id/sliderCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:scaleType="centerInside"/>
            </FrameLayout>
        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===================== DRAWER MENU ===================== -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp"
            android:background="@drawable/bg_blue_card">

            <TextView
                android:id="@+id/drawerDriverName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ZARKIT"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="26sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Partner App"
                android:textColor="#CCDCFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"/>

        <TextView
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:drawablePadding="14dp"
            android:text="  My Profile"/>

        <TextView
            android:id="@+id/menuCurrentTrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="  Current Trip"/>

        <TextView
            android:id="@+id/menuAllTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="  All Trips"/>

        <TextView
            android:id="@+id/menuWithdrawRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="16dp"
            android:text="  Withdraw Requests"/>

        <TextView
            android:id="@+id/menuHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="  Support"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginTop="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"/>

        <TextView
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:gravity="center"
            android:text="Logout"
            android:textColor="#D32F2F"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>