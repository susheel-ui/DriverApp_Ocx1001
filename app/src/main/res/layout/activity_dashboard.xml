<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <!-- MAIN CONTENT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- TOP BAR -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu" />

            <ImageView
                android:id="@+id/logoPorter"
                android:layout_width="80dp"
                android:layout_height="85dp"
                android:layout_marginStart="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/zarkit_nobgblacklogo" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_notification" />

                <ImageView
                    android:id="@+id/btnProfile"
                    android:layout_width="33dp"
                    android:layout_height="33dp"
                    android:src="@drawable/ic_support" />
            </LinearLayout>
        </LinearLayout>

        <!-- GREETING -->
        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hello, Captain 👋"
            android:textColor="#333333"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="8dp" />

        <!-- DRIVER INFO CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/driverInfoCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:padding="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtGreeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="8dp"
                android:paddingHorizontal="4dp"
                android:background="@android:color/white"
                >

                <!-- Driver Profile with Status Dot -->
                <FrameLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp">

                    <ImageView
                        android:id="@+id/imgDriver"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile"
                        android:background="@drawable/circle_white"
                        android:padding="2dp" />

                    <!-- Status Dot -->
                    <ImageView
                        android:id="@+id/statusDot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="2dp"
                        android:background="@drawable/status_dot_green"
                        android:elevation="2dp" />
                </FrameLayout>

                <!-- Driver Info Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amol S*******"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtVehicleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2 Wheeler • MH-12-AB-1234"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- View Profile Button -->
                <TextView
                    android:id="@+id/txtViewProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="VIEW PROFILE"
                    android:textColor="#0D47A1"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- EARNINGS CARD -->
        <LinearLayout
            android:id="@+id/earningCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:backgroundTint="#FFFFFF"
            android:elevation="6dp"
            android:gravity="center_vertical"
            android:layout_weight="1"
            app:layout_constraintTop_toBottomOf="@id/driverInfoCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:radius="16dp">

            <!-- Earnings Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtEarningsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Earnings"
                    android:textColor="#666666"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtEarning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textColor="#222222"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- PAY NOW BUTTON -->
            <Button
                android:id="@+id/btnPayNow"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:backgroundTint="#D32F2F"
                android:text="Pay Now"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:paddingHorizontal="24dp"
                android:stateListAnimator="@null"
                android:elevation="4dp"/>
        </LinearLayout>

        <!-- PRODUCTIVE DAY CARD -->


        <!-- GO ONLINE BUTTON -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="229dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_blue_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.483"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/earningCard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Ready for a productive day?"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Every journey counts. Let's make today your best one yet!"
                android:textColor="#E0E0FF"
                android:textSize="16sp" />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/btnGoOnline"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:background="@drawable/btn_online"
            android:padding="6dp"
            android:elevation="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">


            <TextView
                android:id="@+id/txtOnlineStatus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="GO Online"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/sliderContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_white" />

                <ImageView
                    android:id="@+id/sliderCircle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp"
                    android:scaleType="centerInside" />
            </FrameLayout>
        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- DRAWER MENU -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp">

        <TextView
            android:id="@+id/drawerDriverName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ZARKIT"
            android:paddingTop="32dp"
            android:layout_margin="16dp"
            android:textStyle="bold"
            android:textSize="22sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <TextView
            android:id="@+id/menuProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="My Profile"/>

        <TextView
            android:id="@+id/menuCurrentTrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="Current Trip"/>

        <TextView
            android:id="@+id/menuAllTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="All Trips"/>

        <TextView
            android:id="@+id/menuWithdrawRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="Withdraw Requests"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="16dp"/>

        <TextView
            android:id="@+id/menuHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="Support"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"/>

        <TextView
            android:id="@+id/menuLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/DrawerItem"
            android:text="Logout"
            android:textColor="#D32F2F"/>


    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
