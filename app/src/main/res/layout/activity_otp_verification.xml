<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_card"
    tools:context=".OTP_verifyActivity">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/delivery_image"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/zarkit_nobgblacklogo"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardViewOtp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardElevation="8dp"
        app:cardCornerRadius="24dp"
        app:layout_constraintTop_toBottomOf="@id/delivery_image"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="485dp"
            android:background="@color/white"
            android:padding="24dp">

            <!-- OTP Title -->
            <TextView
                android:id="@+id/otp_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Verify OTP 🔐"
                android:textColor="@android:color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/otp_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enter the OTP sent to your mobile number"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/otp_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Phone Row -->
            <LinearLayout
                android:id="@+id/phone_display_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/otp_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:text="+91"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/phoneNumberTextView"
                    android:text="9XXXXXXXX7"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginStart="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/changeNumberTextView"
                    android:text="CHANGE"
                    android:textColor="@color/color_Primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Auto Read OTP Progress (ABOVE OTP INPUT) -->
            <LinearLayout
                android:id="@+id/auto_read_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/phone_display_layout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:indeterminateTint="#757575"/>

                <TextView
                    android:text="Waiting to auto read OTP"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    android:layout_marginStart="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- OTP Input -->
            <LinearLayout
                android:id="@+id/otp_input_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="12dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/auto_read_layout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <EditText
                    android:id="@+id/otp_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Enter OTP"
                    android:inputType="numberPassword"
                    android:textAlignment="center"
                    android:textColor="#6B7280"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Verify Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/verify_button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Verify OTP"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:backgroundTint="@color/color_Primary"
                app:cornerRadius="24dp"
                app:layout_constraintTop_toBottomOf="@id/otp_input_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Resend OTP -->
            <TextView
                android:id="@+id/resend_sms_button"
                android:text="Resend OTP"
                android:textColor="@color/color_Primary"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/verify_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
